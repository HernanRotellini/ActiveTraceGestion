# activia-trace — Configuración base del backend
# Copiar a .env y completar con valores reales.
# NUNCA versionar .env con secretos reales.

# Base de datos PostgreSQL (asyncpg)
DATABASE_URL="postgresql+asyncpg://trace:trace@localhost:5432/trace"

# Base de datos para tests
DATABASE_URL_TEST="postgresql+asyncpg://trace:trace@localhost:5432/trace_test"

# Firma de JWT (mínimo 32 caracteres)
SECRET_KEY="change-me-to-a-random-secret-key-at-least-32-chars"

# Clave AES-256 para cifrado de PII en reposo (exactamente 32 caracteres = 32 bytes)
ENCRYPTION_KEY="change-me-to-a-32-char-key!!"

# Tiempo de expiración del access token (minutos). Default: 15
ACCESS_TOKEN_EXPIRE_MINUTES=15

# OpenTelemetry (opcional — si no se configura, la app arranca igual)
OTEL_SERVICE_NAME=activia-trace
OTEL_EXPORTER_OTLP_ENDPOINT=
